<t tx="ekr.20260531063728.2062">def createFrame(
    self,
    parent: QWidget,
    name: str,
    hPolicy: Policy = None,
    vPolicy: Policy = None,
    lineWidth: int = 1,
    shadow: Shadow = None,
    shape: Shape = None,
) -&gt; QFrame:
    """Create a Qt Frame."""
    if shadow is None:
        shadow = Shadow.Plain
    if shape is None:
        shape = Shape.NoFrame
    #
    w = QtWidgets.QFrame(parent)
    self.setSizePolicy(w, kind1=hPolicy, kind2=vPolicy)
    w.setFrameShape(shape)
    w.setFrameShadow(shadow)
    w.setLineWidth(lineWidth)
    w.setObjectName(name)
    return w

