<t tx="ekr.20260531063728.4906">def extendLabel(self, s: str, select: bool = False, protect: bool = False) -&gt; None:
    c, k, w = self.c, self, self.w
    if not (w and s):
        return
    c.widgetWantsFocusNow(w)
    w.insert(w.getLastIndex(), s)
    if select:
        i, j = k.getEditableTextRange()
        w.setSelectionRange(i, j, insert=j)
    if protect:
        k.protectLabel()

