<t tx="ekr.20260531063728.5159">@cmd('toggle-find-collapses-nodes')
def toggle_find_collapses_nodes(self, event: LeoKeyEvent) -&gt; None:
    """Toggle the 'Collapse Nodes' checkbox in the find tab."""
    c = self.c
    c.sparse_find = not c.sparse_find
