<t tx="ekr.20260531063728.865">def test_md_import(self):

    # Must be in standard form, with a space after '#'.
    s = """\
        # Top
        The top section

        ## Section 1
        section 1, line 1
        section 1, line 2

        ## Section 2
        section 2, line 1

        ### Section 2.1
        section 2.1, line 1

        #### Section 2.1.1
        section 2.2.1 line 1
        The next section is empty. It must not be deleted.

        ### Section 2.2

        ## Section 3
        Section 3, line 1
    """
    expected_results = (
        (
            0, '',  # Ignore the first headline.
            '@language md\n'
            '@tabwidth -4\n'
        ),
        (
            1, 'Top',
            'The top section\n'
            '\n'
        ),
        (
            2, 'Section 1',
            'section 1, line 1\n'
            'section 1, line 2\n'
            '\n'
        ),
        (
            2, 'Section 2',
            'section 2, line 1\n'
            '\n'
        ),
        (
            3, 'Section 2.1',
            'section 2.1, line 1\n'
            '\n'
        ),
        (
            4, 'Section 2.1.1',
            'section 2.2.1 line 1\n'
            'The next section is empty. It must not be deleted.\n'
            '\n'
        ),
        (
            3, 'Section 2.2',
            '\n'
        ),
        (
            2, 'Section 3',
            'Section 3, line 1\n'
        ),
    )  # fmt: skip
    self.new_run_test(s, expected_results)

