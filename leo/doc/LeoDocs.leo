def isTextWrapper(self, w: Any) -&gt; bool:
    """Return True if w is a Text widget suitable for text-oriented commands."""
    if w is None:
        return False
    if isinstance(w, (g.NullObject, g.TracingNullObject)):
        return True
    return issubclass(w.__class__, QTextMixin)

