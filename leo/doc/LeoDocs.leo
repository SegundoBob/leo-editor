<t tx="ekr.20260531063728.5102">def createFontPicker(self, tabName: str) -&gt; None:
    # log = self
    font, ok = QtWidgets.QFontDialog.getFont()
    if not (font and ok):
        return
    style = font.style()
    style_s: str = ''
    table1 = (
        (Style.StyleNormal, 'normal'),  # #2330.
        (Style.StyleItalic, 'italic'),
        (Style.StyleOblique, 'oblique'),
    )
    for val, name in table1:
        if style == val:
            style_s = name
            break
    weight: int = font.weight()
    weight_s: str = ''
    table2 = (
        (Weight.Light,    'light'),  # #2330.
        (Weight.Normal,   'normal'),
        (Weight.DemiBold, 'demibold'),
        (Weight.Bold,     'bold'),
        (Weight.Black,    'black'),
    )  # fmt: skip
    for val2, name2 in table2:
        if weight == val2:
            weight_s = name2
            break
    table3 = (
        ('family', str(font.family())),
        ('size  ', font.pointSize()),
        ('style ', style_s),
        ('weight', weight_s),
    )
    for key3, val3 in table3:
        if val3:
            g.es(key3, val3, tabName='Fonts')

