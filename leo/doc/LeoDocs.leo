<t tx="ekr.20260531063728.3475">def createTreeEditorForItem(self, item: QTreeWidgetItem) -&gt; None:
    c = self.c
    w = self.treeWidget
    w.setCurrentItem(item)  # Must do this first.
    if self.use_declutter:
        item.setText(0, item._real_text)
    w.editItem(item)
    e = w.itemWidget(item, 0)  # e is a QLineEdit
    if e:
        e.setObjectName('headline')
    # Always do these!
    self.connectEditorWidget(e, item)
    self.sizeTreeEditor(c, e)

