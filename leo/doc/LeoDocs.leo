<t tx="ekr.20260531063728.37">def get_str_lws(self, s: str) -&gt; str:
    """Return the characters of the lws of s."""
    m = re.match(r'([ \t]*)', s)
    return m.group(0) if m else ''

</t>
<t tx="ekr.20260531063728.38">def remove_common_lws(self, lws: str, lines: list[str]) -&gt; list[str]:
    """Remove the given leading whitespace from the given lines."""
    if len(lws) == 0:
        return lines
    assert lws.isspace(), repr(lws)
    n = len(lws)
    result: list[str] = []
    for line in lines:
        stripped_line = line.strip()
        if stripped_line:
            assert line[:n].isspace(), repr(line)
            result.append(line[n:])
        else:
            result.append(line)
    return result

