<t tx="ekr.20260531063728.4277">def reload_settings(self) -&gt; None:
    """Reload all abbreviation settings."""
    self.abbrevs = {}
    self.init_settings()
    self.init_abbrev()
    self.init_tree_abbrev()
    self.init_env()

reloadSettings = reload_settings

