<t tx="ekr.20260531063728.4919">def updateLabel(self, event: LeoKeyEvent) -&gt; None:
    """
    Mimic what would happen with the keyboard and a Text editor
    instead of plain accumulation.
    """
    c, k, w = self.c, self, self.w
    if not event:
        return
    ch, stroke = event.char, event.stroke
    if ch in "\n\r":
        return
    if ch != '\b' and stroke and not k.isPlainKey(stroke):
        return  # #2041.
    c.widgetWantsFocusNow(w)
    i, j = w.getSelectionRange()
    ins = w.getInsertPoint()
    if i != j:
        w.delete(i, j)
    if ch == '\b':
        s = w.getAllText()
        if len(s) &gt; len(k.mb_prefix):
            w.delete(i - 1)
            i -= 1
    else:
        w.insert(ins, ch)
        i = ins + 1

