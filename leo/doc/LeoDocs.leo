<t tx="ekr.20260531063728.860">def test_is_underline(self):
    c = self.c
    x = markdown.Markdown_Importer(c)
    for line in (
        '----\n',
        '-----\n',
        '====\n',
        '====\n'
    ):  # fmt: skip
        got = x.is_underline(line)
        assert got, repr(line)
    for line in (
        '-\n',
        '--\n',
        '---\n',
        '==\n',
        '===\n',
        '===\n',
        '==-==\n',
        'abc\n',
    ):  # fmt: skip
        got = x.is_underline(line)
        assert not got, repr(line)

