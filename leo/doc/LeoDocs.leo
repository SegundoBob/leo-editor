<t tx="ekr.20260531063728.96">public class SplitTest {
    @others


}
</t>
<t tx="ekr.20260531063728.97">private String path = "word_job_counts.txt";

Hashtable&lt;String,Integer&gt; getCounts() throws IOException {
    FileReader r = new FileReader(path);
    BufferedReader br = new BufferedReader(r, 30000);
    Hashtable&lt;String, Integer&gt; counts = new Hashtable&lt;String,Integer&gt;();
    
    String line;
    String[] fields;

    while ((line = br.readLine()) != null) {
        fields = line.split("\\t");
        counts.put(fields[1], Integer.valueOf(fields[0]));
    }

    br.close();

    return counts;
}

</t>
<t tx="ekr.20260531063728.98">public static void main(String[] args) throws IOException {
    Hashtable &lt;String, Integer&gt; words = (new SplitTest()).getCounts();
    int len = words.size();
    System.out.println(len);

    Set wordset = Collections.synchronizedSet(words.keySet());
    Object [] wordlist = wordset.toArray();
    Arrays.sort(wordlist);
    System.out.println(wordlist[0]);

        
}
</t>
