<t tx="ekr.20260531063728.3482">def getWrapper(self, e: QLineEdit, item: QTreeWidgetItem) -&gt; QHeadlineWrapper:
    """Return the QHeadlineWrapper that wraps e (a QLineEdit)."""
    c = self.c
    if not e:
        return None
    if wrapper := self.editWidgetsDict.get(e):
        return wrapper
    if not item:
        return None
    wrapper = qt_text.QHeadlineWrapper(c, item, name='head', widget=e)
    self.editWidgetsDict[e] = wrapper
    return wrapper

