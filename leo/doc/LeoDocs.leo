<t tx="ekr.20260531063728.4650">def close_Server() -&gt; None:
    """
    Close the server by stopping the loop
    """
    global gLoop
    if gLoop and gLoop.is_running():
        print('Closing Leo Server', flush=True)
        gLoop.stop()
        gLoop = None

