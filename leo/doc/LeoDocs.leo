<t tx="ekr.20260531063728.821">g.cls()
from leo.plugins.qt_text import (
    QHeadlineWrapper,
    QLineEditWrapper,
    QMinibufferWrapper,
    QScintillaWrapper,
    QTextEditWrapper,
    QTextMixin,
)

for class_ in (
    QHeadlineWrapper,
    QLineEditWrapper,
    QMinibufferWrapper,
    QTextEditWrapper,
    QScintillaWrapper,
    QTextMixin,  # Every class is a subclass of itself.
):
    print(class_)
    assert issubclass(class_, QTextMixin), repr(class_)
print('')
for obj in (
    c.frame.body.wrapper,
    c.frame.miniBufferWidget,
):
    print(obj.__class__)
    assert issubclass(obj.__class__, QTextMixin), repr(obj)
    assert isinstance(obj, QTextMixin), repr(obj)
print('Done!')
