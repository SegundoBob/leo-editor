<t tx="ekr.20260531063728.5268">@cmd('abbrev-list')
def listAbbrevs(self, event: LeoKeyEvent = None) -&gt; None:
    """List all abbreviations."""
    d = self.abbrevs
    if not d:
        return
    g.es_print('')
    g.es_print(f"Abbreviations for {self.c.shortFileName()}...")
    for name, s in sorted(d.items()):
        s = s.replace('\n', '\\n')
        tail = s.removesuffix('\\n')
        g.es_print(f"{name:&gt;15} {g.truncate(tail, 90)}")

