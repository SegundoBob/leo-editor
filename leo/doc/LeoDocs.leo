<t tx="ekr.20260531063728.205">def getSelectionRange(self, sort: bool = True) -&gt; tuple[int, int]:
    """Get the selection range from a QsciScintilla widget."""
    w = self.widget
    i = int(w.SendScintilla(w.SCI_GETCURRENTPOS))
    j = int(w.SendScintilla(w.SCI_GETANCHOR))
    if sort and i &gt; j:
        i, j = j, i
    return i, j

