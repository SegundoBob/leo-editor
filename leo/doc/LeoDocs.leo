            '    &lt;link id="L1"&gt;\n'
            '    &lt;link id="L2"&gt;\n'
            '    &lt;link id="L3" /&gt;\n'
            "    &lt;link id='L4' /&gt;\n"
            '\n'
            '    &lt;title&gt;TITLE&lt;/title&gt;\n'
            '\n'
            '&lt;!-- oops: missing tags. --&gt;\n'
            '@language html\n'
            '@tabwidth -4\n'
        ),
        (
            1, '&lt;head&gt;',
            '&lt;html&gt;\n\n&lt;head&gt;\n'
        ),
    )  # fmt: skip
