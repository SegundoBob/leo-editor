<t tx="ekr.20260531063728.586">def headline_wrapper(self, p: Position) -&gt; QTextMixin:
    d = self.editWidgetsDict
    if not p or not p.v:
        return None
    w = d.get(p.v)
    if not w:
        d[p.v] = w = StringTextWrapper(c=self.c, name=f"head-{1 + len(list(d.keys())):d}")
        w.setAllText(p.h)
    return w

