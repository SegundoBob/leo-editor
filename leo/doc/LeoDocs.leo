<t tx="ekr.20260531063728.882">def test_regex(self):

    s = """
        #!/usr/bin/perl

        sub test1 {
            s = /}/g;
        }

        sub test2 {
            s = m//}/;
        }

        sub test3 {
            s = s///}/;
        }

        sub test4 {
            s = tr///}/;
        }
    """
    expected_results = (
        (
            0, '',  # Ignore the first headline.
            '@others\n'
            '@language perl\n'
            '@tabwidth -4\n'
        ),
        (
            1, 'sub test1',
            '#!/usr/bin/perl\n\nsub test1 {\n'
            '    s = /}/g;\n'
            '}\n'
            '\n'
        ),
        (
            1, 'sub test2',
            'sub test2 {\n'
            '    s = m//}/;\n'
            '}\n'
            '\n'
        ),
        (
            1, 'sub test3',
            'sub test3 {\n'
            '    s = s///}/;\n'
            '}\n'
            '\n'
        ),
        (
            1, 'sub test4',
            'sub test4 {\n'
            '    s = tr///}/;\n'
            '}\n'
        ),
    )  # fmt: skip
    self.new_run_test(s, expected_results)

