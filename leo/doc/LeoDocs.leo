        ),
        (
            1, 'fn comment_contains_code_basic',
            '#[test]\n'
            'fn comment_contains_code_basic() {\n'
            '    assert!(comment_contains_code("#import eradicate", &amp;[]));\n'
            '    assert!(comment_contains_code(r#"#"key": value,"#, &amp;[]));\n'
            '    assert!(comment_contains_code(r#"#"key": "value","#, &amp;[]));\n'
            '}\n'
        ),
