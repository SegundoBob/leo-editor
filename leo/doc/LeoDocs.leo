<t tx="ekr.20260531063728.57">def postprocess(self, parent: Position) -&gt; None:
    """Java_Importer.postprocess."""

    # Base-class method.
    self.move_blank_lines(parent)

    # Subclass methods...
    self.move_module_preamble(parent)

