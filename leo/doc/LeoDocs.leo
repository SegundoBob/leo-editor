<t tx="ekr.20260531063728.2052">def _self_and_subtree(self, qt_obj: QObject) -&gt; Generator:
    """Yield w and all of w's descendants."""
    if not qt_obj:
        return
    yield qt_obj
    for child in qt_obj.children():
        yield from self._self_and_subtree(child)

