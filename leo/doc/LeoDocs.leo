<t tx="ekr.20260531063728.3877">def test_addAbbrevHelper(self):
    c = self.c
    f = c.abbrevCommands.addAbbrevHelper
    d = c.abbrevCommands.abbrevs

    # New in Leo 4.10: whitespace (blank,tab,newline) *is* significant in definitions.
    table = (
        ('ut1',  'ut1=aa',       'aa'),
        # ('ut2','ut2 =bb',      'bb'),
        ('ut3',  'ut3=cc=dd',    'cc=dd'),
        ('ut4',  'ut4= ee',      ' ee'),
        ('ut5',  'ut5= ff = gg', ' ff = gg'),
        ('ut6',  'ut6= hh==ii',  ' hh==ii'),
        ('ut7',  'ut7=j=k',      'j=k'),
        ('ut8',  'ut8=l==m',     'l==m'),
        ('@ut1', '@ut1=@a',      '@a'),
    )  # fmt: skip
    for name, s, expected in table:
        for s2, kind in ((s, '(no nl)'), (s + '\n', '(nl)')):
            f(s2, tag='unit-test')
            result = d.get(name)
            self.assertEqual(result, expected, msg=kind)

