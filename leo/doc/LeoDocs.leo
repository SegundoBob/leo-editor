<t tx="ekr.20260531063728.1788">def injectIvars(self, c: Cmdr) -&gt; QTextMixin:
    """Inject standard leo ivars into the QTextEdit or QsciScintilla widget."""
    w = self
    w.leo_active = True
    # New in Leo 4.4.4 final: inject the scrollbar items into the text widget.
    w.leo_bodyBar = None
    w.leo_bodyXBar = None
    w.leo_frame = None
    return w

