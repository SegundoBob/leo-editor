<t tx="ekr.20260531063728.840">def test_elisp_1(self):

    # Add weird assignments for coverage.
    s = """
        ;;; comment
        ;;; continue
        ;;;

        (defun abc (a b)
           (assn a "abc")
           (assn b \\x)
           (+ 1 2 3))

        ; comment re cde
        (defun cde (a b)
           (+ 1 2 3))
    """
    expected_results = (
        (
            0, '',  # Ignore the first headline.
            '@others\n'
            '@language lisp\n'
            '@tabwidth -4\n'
        ),
        (
            1, 'defun abc',
            ';;; comment\n'
            ';;; continue\n'
            ';;;\n'
            '\n'
            '(defun abc (a b)\n'
            '   (assn a "abc")\n'
            '   (assn b \\x)\n'
            '   (+ 1 2 3))\n'
            '\n'
        ),
        (
            1, 'defun cde',
            '; comment re cde\n(defun cde (a b)\n'
            '   (+ 1 2 3))\n'
        ),
    )  # fmt: skip
    self.new_run_test(s, expected_results)

