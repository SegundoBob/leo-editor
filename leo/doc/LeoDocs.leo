<t tx="ekr.20260531063728.4705">def getSelectionRange(self, sort: bool = True) -&gt; tuple[int, int]:
    """QHeadlineWrapper."""
    w = self.widget
    if self.check():
        if w.hasSelectedText():
            i = w.selectionStart()
            s = w.selectedText()
            j = i + len(s)
        else:
            i = j = w.cursorPosition()
        return i, j
    return 0, 0

