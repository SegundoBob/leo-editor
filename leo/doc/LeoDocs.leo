    if getattr(w, 'widget', None):
        if not isinstance(w, QtWidgets.QWidget):
            # w should be a wrapper.
            w = w.widget
    if 'focus' in g.app.debug:
        name = w.objectName() if hasattr(w, 'objectName') else w.__class__.__name__
        g.trace('(LeoQtGui)', name)
    w.setFocus()

