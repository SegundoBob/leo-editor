def getImageImage(self, name: str) -&gt; Optional[QPixmap]:
    """Load the image in file named `name` and return it."""
    fullname = self.getImageFinder(name)
    try:
        pixmap = QtGui.QPixmap()
        pixmap.load(fullname)
        return pixmap
    except Exception:
        g.es("exception loading:", name)
        g.es_exception()
        return None

