<t tx="ekr.20260531063728.4934">def getStrokeForCommandName(self, commandName: str) -&gt; Optional[Stroke]:
    c, k = self.c, self
    command = c.commandsDict.get(commandName)
    if command:
        for stroke, aList in k.bindingsDict.items():
            for bi in aList:
                if bi.commandName == commandName:
                    return stroke
    return None

