<t tx="ekr.20260531063728.1952">def compute_ratio(self) -&gt; float:
    """
    Return ratio of the main Qt splitter or 0.5.
    """
    c = self.c
    gui = g.app.gui
    w = gui.find_widget_by_name(c, 'main_splitter')
    if not w:
        return 0.5
    aList = w.sizes()
    if len(aList) == 2:
        n1, n2 = aList
        # Don't divide by zero.
        ratio = 0.5 if n1 + n2 == 0 else float(n1) / float(n1 + n2)
        return ratio
    return 0.5

</t>
<t tx="ekr.20260531063728.1953">def compute_secondary_ratio(self) -&gt; float:
    """
    Return the ratio of the Qt secondary splitter or 0.5.
    """
    c = self.c
    gui = g.app.gui
    w = gui.find_widget_by_name(c, 'secondary_splitter')
    if w is None:
        return 0.5
    aList = w.sizes()
    if len(aList) == 2:
        n1, n2 = aList
        return float(n1) / float(n1 + n2) if n2 &gt; 0 else 0.5
    return 0.5

</t>
