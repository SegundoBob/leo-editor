    """
    Get arguments from the command line and sets them globally.
    """
    global wsHost, wsPort, wsLimit, wsPersist, wsSkipDirty, argFile, wsPassword, wsCert, wsKey

    def leo_file(s: str) -&gt; str:
        if os.path.exists(s):
