<t tx="ekr.20260531063728.197">def delete(self, i: int, j: int = None) -&gt; None:
    """Delete s[i:j]"""
    w = self.widget
    if j is None:
        j = i + 1
    self.setSelectionRange(i, j)
    try:
        self.changingText = True  # Disable onTextChanged
        w.replaceSelectedText('')
    finally:
        self.changingText = False

