<t tx="ekr.20260531063728.4837">def dumpMasterBindingsDict(self) -&gt; None:
    """Dump k.masterBindingsDict."""
    k = self
    d = k.masterBindingsDict
    g.pr('\nk.masterBindingsDict...\n')
    for key in sorted(d):
        g.pr(key, '-' * 40)
        d2 = d.get(key)
        for key2 in sorted(d2):
            bi = d2.get(key2)
            g.pr(f"{key2:20} {bi.commandName}")

