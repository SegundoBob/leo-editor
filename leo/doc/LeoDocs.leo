<t tx="ekr.20260531063728.5155">def editShortcut_do_bind_helper(self, stroke: Stroke, cmdname: str) -&gt; None:
    c, k = self.c, self
    cmdfunc = c.commandsDict.get(cmdname)
    if cmdfunc:
        k.bindKey('all', stroke, cmdfunc, cmdname)
        g.es('bound', stroke, 'to command', cmdname)

