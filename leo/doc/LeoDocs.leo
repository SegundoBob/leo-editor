<t tx="ekr.20260531063728.857">def test_var_equal_function(self):

    s = """
        var c3 = (function () {
            "use strict";

            // Globals
            var c3 = { version: "0.0.1"   };

            c3.someFunction = function () {
                console.log("Just a demo...");
            };

            return c3;
        }());
    """

    expected_results = (
        (
            0, '',  # Ignore the first headline.
            '@others\n'
            '@language javascript\n'
            '@tabwidth -4\n'
        ),
        (
            1, 'function c3',
            'var c3 = (function () {\n'
            '    @others\n'
            '\n'
            '    return c3;\n'
            '}());\n'
        ),
        (
            2, 'function c3.someFunction',
            '"use strict";\n'
            '\n'
            '// Globals\n'
            'var c3 = { version: "0.0.1"   };\n'
            '\n'
            'c3.someFunction = function () {\n'
            '    console.log("Just a demo...");\n'
            '};\n'
        ),
    )  # fmt: skip
    self.new_run_test(s, expected_results)

