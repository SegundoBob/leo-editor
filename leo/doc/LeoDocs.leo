<t tx="ekr.20260531063728.2028">def runScrolledMessageDialog(
    self,
    short_title: str = '',
    title: str = 'Message',
    label: str = '',
    msg: str = '',
    c: Cmdr = None,
    **keys: Any,
) -&gt; None:
    if g.unitTesting:
        return None

    def send() -&gt; Any:
        return g.doHook(
            'scrolledMessage',
            short_title=short_title,
            title=title,
            label=label,
            msg=msg,
            c=c,
            **keys,
        )

    if not c or not c.exists:
        &lt;&lt; no c error&gt;&gt;
    else:
        retval = send()
        if retval:
            return retval
        &lt;&lt; load viewrendered plugin &gt;&gt;
        retval = send()
        if retval:
            return retval
        &lt;&lt; no dialog error &gt;&gt;
    &lt;&lt; emergency fallback &gt;&gt;

