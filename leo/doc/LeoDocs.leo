<t tx="ekr.20260531063728.208">def insert(self, i: int, s: str) -&gt; int:
    """Insert s at position i."""
    w = self.widget
    w.SendScintilla(w.SCI_SETSEL, i, i)
    w.SendScintilla(w.SCI_ADDTEXT, len(s), g.toEncodedString(s))
    i += len(s)
