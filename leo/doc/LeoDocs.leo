<t tx="ekr.20260531063728.913">def test_treepad_1(self):
    # 5P9i0s8y19Z is a magic number.
    # The treepad writer always writes '&lt;Treepad version 3.0&gt;',
    # but any version should work.
    s = """
        &lt;Treepad version 2.7&gt;
        dt=Text
        &lt;node&gt; 5P9i0s8y19Z
        headline 1
        0
        node 1, line 1
        node 1, line 2
        &lt;end node&gt; 5P9i0s8y19Z
        dt=Text
        &lt;node&gt; 5P9i0s8y19Z
        headline 1.1
        1
        node 1.1, line 1
        &lt;end node&gt; 5P9i0s8y19Z
        dt=Text
        &lt;node&gt; 5P9i0s8y19Z
        headline 1.2
        1
        node 1.2, line 1
        node 1.2, line 2
        &lt;end node&gt; 5P9i0s8y19Z
        dt=Text
        &lt;node&gt; 5P9i0s8y19Z
        headline 2
        0
        node 2, line 1
        node 2, line 2
        &lt;end node&gt; 5P9i0s8y19Z
        dt=Text
        &lt;node&gt; 5P9i0s8y19Z
        headline 2.1.1
        3
        node 2.1.1, line 1
        node 2.1.1, line 2
        &lt;end node&gt; 5P9i0s8y19Z
    """

    expected_results = (
        (
            0, '',  # Ignore the first headline.
            '&lt;Treepad version 2.7&gt;\n'
            '@others\n'
            '@language plain\n'
            '@tabwidth -4\n'
        ),
        (
            1, 'headline 1',
            'node 1, line 1\n'
            'node 1, line 2\n'
        ),
        (
            2, 'headline 1.1',
            'node 1.1, line 1\n'
        ),
        (
            2, 'headline 1.2',
            'node 1.2, line 1\n'
            'node 1.2, line 2\n'
        ),
        (
            1, 'headline 2',
            'node 2, line 1\n'
            'node 2, line 2\n'
        ),
        (
            2, 'placeholder level 2',
            ''
        ),
        (
            3, 'placeholder level 3',
            ''
        ),
        (
            4, 'headline 2.1.1',
            'node 2.1.1, line 1\n'
            'node 2.1.1, line 2\n'
        ),
    )  # fmt: skip
    self.new_run_test(s, expected_results)

