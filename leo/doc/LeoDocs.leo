<t tx="ekr.20260531063728.2006">def getTextFromClipboard(self) -&gt; str:
    """Get a unicode string from the clipboard."""
    cb = self.qtApp.clipboard()
    if cb:
        QtWidgets.QApplication.processEvents()
        return cb.text()
    g.trace('no clipboard!')
    return ''

