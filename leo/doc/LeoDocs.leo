<t tx="ekr.20260531063728.3493">def headline_wrapper(self, p: Position) -&gt; QHeadlineWrapper:
    """Returns the edit widget (A QLineEdit) for position p."""
    item = self.position2item(p)
    if item:
        e = self.getTreeEditorForItem(item)
        if e:
            # Create a wrapper widget for Leo's core.
            w = self.getWrapper(e, item)
            return w
        # This is not an error
        # But warning: calling this method twice might not work!
        return None
    return None

edit_widget = headline_wrapper  # Compatibility.

