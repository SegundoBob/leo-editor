<t tx="ekr.20260531063728.879">def test_1(self):

    s = """
        #!/usr/bin/perl

        # Function definition
        sub Hello{
           print "Hello, World!\n";
        }

        sub Test{
           print "Test!\n";
        }
        "\N{LATIN SMALL LIGATURE FI}" =~ /fi/i;

        $bar = "foo";
        if ($bar =~ /foo/){
           print "Second time is matching\n";
        }else{
           print "Second time is not matching\n";
        }

        # Function call
        Hello();
    """
    expected_results = (
        (
            0, '',  # Ignore the first headline.
            '@others\n'
            '            "ﬁ" =~ /fi/i;\n'
            '\n'
            '            $bar = "foo";\n'
            '            if ($bar =~ /foo/){\n'
            '               print "Second time is matching\n'
            '";\n'
            '            }else{\n'
            '               print "Second time is not matching\n'
            '";\n'
            '            }\n'
            '\n'
            '            # Function call\n'
            '            Hello();\n'
            '@language perl\n'
            '@tabwidth -4\n'
        ),
        (
            1,
            'sub Hello',
            '#!/usr/bin/perl\n'
            '\n'
            '            # Function definition\n'
            '            sub Hello{\n'
            '               print "Hello, World!\n'
            '";\n'
            '            }\n'
            '\n'
        ),
        (
            1, 'sub Test',
            '            sub Test{\n'
            '               print "Test!\n";\n'
            '            }\n'
        ),
    )  # fmt: skip
    self.new_run_test(s, expected_results)

