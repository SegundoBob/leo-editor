<t tx="ekr.20260531063728.2904">@g.command('show-clone-parents')
def show_clones(event: LeoKeyEvent = None) -&gt; None:
    """Display links to all parent nodes of the node c.p."""
    c = event.get('c')
    if not c:
        return
    seen: set[str] = set()
    g.es(f"Parents of {c.p.h}...")
    for clone in c.vnode2allPositions(c.p.v):
        parent = clone.parent()
        if parent:
            unl = message = parent.get_legacy_UNL()
            # Drop the file part.
            i = unl.find('#')
            if i &gt;= 0:
                message = unl[i + 1 :]
            if message not in seen:
                seen.add(message)
                c.frame.log.put(message + '\n', nodeLink=f"{unl}::1")


