        &lt;head&gt;
            &lt;!-- oops: link elements terminated two different ways --&gt;
            &lt;link id="L1"&gt;
            &lt;link id="L2"&gt;
            &lt;link id="L3" /&gt;
            &lt;link id='L4' /&gt;

            &lt;title&gt;TITLE&lt;/title&gt;

        &lt;!-- oops: missing tags. --&gt;
    '''
