<t tx="ekr.20260531063728.894">def test_oneliners(self):
    s = """
        import sys
        def f1():
            pass

        class Class1:pass
        a = 2
        @dec_for_f2
        def f2(): pass

        def main():
            pass

        if __name__ == '__main__':
            main()
    """

    expected_results = (
        (
            0, '',  # Ignore the first headline.
            'import sys\n'
            '@others\n'
            '\n'
            "if __name__ == '__main__':\n"
            '    main()\n'
            '@language python\n'
            '@tabwidth -4\n'
        ),
        (
            1, 'function: f1',
            'def f1():\n'
            '    pass\n'
            '\n'
        ),
        (
            1, 'class Class1',
            'class Class1:pass\n'
        ),
        (
            1, 'function: f2',
            'a = 2\n'
            '@dec_for_f2\n'
            'def f2(): pass\n'
            '\n'
        ),
        (
            1, 'function: main',
            'def main():\n'
            '    pass\n'
        ),
    )  # fmt: skip
    self.new_run_test(s, expected_results)

