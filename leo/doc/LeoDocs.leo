</t>
<t tx="ekr.20260531063728.3523">def setSelectionRange(self, i: int, j: int, insert: int = None) -&gt; None:
    """Set the selection range and the insert point."""
    c = self.c
    # Part 1
    w = self.widget
    s = self.getAllText()
    if i is None:
        i = 0
    if j is None:
        j = i
    n = len(s)
    i = max(0, min(i, n))
    j = max(0, min(j, n))
    if insert is None:
        ins = max(i, j)
    else:
        ins = j if insert is None else insert
        ins = max(0, min(ins, n))

    # Part 2: Use tc.setPosition. tc.movePosition doesn't work.
    tc = w.textCursor()
    if i == j:
        tc.setPosition(i)
    elif ins == j:
        # Put the insert point at j
        tc.setPosition(i)
        tc.setPosition(j, MoveMode.KeepAnchor)
    elif ins == i:
        # Put the insert point at i
        tc.setPosition(j)
        tc.setPosition(i, MoveMode.KeepAnchor)
    else:
        # 2014/08/21: It doesn't seem possible to put the insert point somewhere else!
        tc.setPosition(j)
        tc.setPosition(i, MoveMode.KeepAnchor)
    w.setTextCursor(tc)
    # #218.
    if hasattr(g.app.gui, 'setClipboardSelection'):
        if s[i:j]:
            g.app.gui.setClipboardSelection(s[i:j])
    # Remember the values for v.restoreCursorAndScroll.
    if not c:
        return
    v = c.p.v
    if not v:
        return
    v.insertSpot = ins
    if i &gt; j:
        i, j = j, i
    assert i &lt;= j
    v.selectionStart = i
    v.selectionLength = j - i
    v.scrollBarSpot = w.verticalScrollBar().value()

