<t tx="ekr.20260531063728.1992">def getFullVersion(self, c: Cmdr = None) -&gt; str:
    """Return the PyQt version (for signon)"""
    try:
        qtLevel = f"version {QtCore.qVersion()}"
    except Exception:
        # g.es_exception()
        qtLevel = '&lt;qtLevel&gt;'
    return f"PyQt {qtLevel}"

