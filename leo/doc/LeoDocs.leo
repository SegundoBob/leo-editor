    if 'focus' in g.app.debug:
        g.trace(c1)
    if hasattr(g.app.gui, 'frameFactory'):
        factory = g.app.gui.frameFactory
        if factory and hasattr(factory, 'setTabForCommander'):
            c = c1
            factory.setTabForCommander(c)
            c.bodyWantsFocusNow()

